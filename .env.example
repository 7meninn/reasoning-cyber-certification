# Default mode runs locally and does not require cloud credentials.
APP_MODE=mock

# Phase 3 optional Foundry mode. Use Microsoft Entra ID via `az login`;
# do not commit secrets or API keys.
# APP_MODE=foundry
# AZURE_AI_PROJECT_ENDPOINT=
# AZURE_AI_MODEL_DEPLOYMENT=
# AZURE_OPENAI_API_VERSION=2024-10-21

# Phase 4 optional Foundry IQ grounding. This keeps model-backed agents
# and replaces local mock retrieval with a Foundry IQ / Azure AI Search
# knowledge base retrieve call. If retrieval fails, the app falls back
# visibly to local_mock.
# APP_MODE=foundry_iq
# AZURE_AI_SEARCH_ENDPOINT=
# FOUNDRY_IQ_KNOWLEDGE_BASE=
# FOUNDRY_IQ_API_VERSION=2026-05-01-preview
# FOUNDRY_IQ_MAX_DOCS=8
# FOUNDRY_IQ_MAX_OUTPUT_TOKENS=4096
