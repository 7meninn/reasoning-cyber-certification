# Copy to .env for local experimentation only. Do not commit .env.

# mock | foundry | foundry_iq
APP_MODE=mock

# Required for APP_MODE=foundry and APP_MODE=foundry_iq.
AZURE_AI_PROJECT_ENDPOINT=https://<resource>.services.ai.azure.com/api/projects/<project>
AZURE_AI_MODEL_DEPLOYMENT=<deployment-name>

# Required only for APP_MODE=foundry_iq.
AZURE_AI_SEARCH_ENDPOINT=https://<search-service>.search.windows.net
FOUNDRY_IQ_KNOWLEDGE_BASE=<knowledge-base-name>

# Optional tuning.
AZURE_OPENAI_API_VERSION=2024-10-21
FOUNDRY_IQ_API_VERSION=2026-05-01-preview
FOUNDRY_IQ_MAX_DOCS=8
FOUNDRY_IQ_MAX_OUTPUT_TOKENS=4096

# Hosted agent API.
HOSTED_AGENT_API_HOST=0.0.0.0
HOSTED_AGENT_API_PORT=8000
